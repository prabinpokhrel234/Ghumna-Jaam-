rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    // Checking verified email of signed in user
    function isVerified() {
      return isSignedIn();
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidBlog(data) {
      return data.keys().hasAll(['title', 'subtitle', 'content', 'category', 'image', 'authorId', 'authorName', 'authorEmail', 'createdAt', 'updatedAt']) 
        && data.keys().size() == 10
        && data.title is string && data.title.size() >= 3 && data.title.size() <= 150
        && data.subtitle is string && data.subtitle.size() >= 3 && data.subtitle.size() <= 250
        && data.content is string && data.content.size() >= 10 && data.content.size() <= 10000
        && data.category is string && data.category.size() <= 50
        && data.image is string && data.image.size() <= 1000
        && data.authorId is string && data.authorId == request.auth.uid
        && data.authorName is string && data.authorName.size() <= 100
        && data.authorEmail is string && data.authorEmail.size() <= 100;
    }

    // Blogs Collection rules
    match /blogs/{blogId} {
      allow read: if true;
      
      allow create: if isVerified() 
        && isValidId(blogId) 
        && isValidBlog(incoming()) 
        && incoming().createdAt == request.time 
        && incoming().updatedAt == request.time;
        
      allow update: if isVerified() 
        && isValidId(blogId) 
        && isValidBlog(incoming()) 
        && incoming().authorId == existing().authorId 
        && incoming().createdAt == existing().createdAt 
        && incoming().updatedAt == request.time 
        && existing().authorId == request.auth.uid;
        
      allow delete: if isVerified() 
        && isValidId(blogId) 
        && existing().authorId == request.auth.uid;
    }
  }
}
